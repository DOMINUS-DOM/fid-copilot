INSERT INTO public.legal_chunks (cda_code, article_number, paragraph, content, citation_display) VALUES
('46239', '63', '1', 'Article 63. - § 1er. Le Gouvernement nomme, [après accomplissement 
d''un stage d''un an]242: 
1° cinq Inspecteurs coordonnateurs, chargés de la coordination des 
missions de l''Inspection au niveau de l''enseignement du continuum 
